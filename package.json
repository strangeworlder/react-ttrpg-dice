{
  "name": "react-ttrpg-dice",
  "version": "0.0.1",
  "description": "Plug-and-play React component for rolling polyhedral TTRPG dice with WebGPU physics",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "THIRD_PARTY_NOTICES"],
  "sideEffects": false,
  "scripts": {
    "build": "bunchee",
    "dev": "bunchee --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepack": "npm run test:run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strangeworlder/react-ttrpg-dice.git"
  },
  "homepage": "https://github.com/strangeworlder/react-ttrpg-dice#readme",
  "bugs": {
    "url": "https://github.com/strangeworlder/react-ttrpg-dice/issues"
  },
  "author": "strangeworlder",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.171.0",
    "@react-three/fiber": ">=9.0.0",
    "@react-three/rapier": ">=1.5.0"
  },
  "devDependencies": {
    "bunchee": "latest",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "three": "^0.175.0",
    "@types/three": "^0.175.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/rapier": "^2.1.0"
  },
  "engines": { "node": ">=20" },
  "license": "MIT",
  "keywords": ["react", "dice", "ttrpg", "3d", "physics", "webgpu", "rapier"]
}
